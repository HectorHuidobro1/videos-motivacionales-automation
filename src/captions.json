[
  {
    "start": 0.0,
    "end": 1.42,
    "text": "La motivación te"
  },
  {
    "start": 1.42,
    "end": 3.18,
    "text": "abandona, justo cuando"
  },
  {
    "start": 3.18,
    "end": 4.44,
    "text": "más la necesitas."
  },
  {
    "start": 5.42,
    "end": 6.46,
    "text": "Por eso, las"
  },
  {
    "start": 6.46,
    "end": 7.58,
    "text": "personas que logran"
  },
  {
    "start": 7.58,
    "end": 9.04,
    "text": "algo grande no"
  },
  {
    "start": 9.04,
    "end": 10.78,
    "text": "esperan sentirse inspiradas."
  },
  {
    "start": 11.38,
    "end": 13.12,
    "text": "Actúan igual, con"
  },
  {
    "start": 13.12,
    "end": 14.64,
    "text": "ganas o singanas."
  },
  {
    "start": 16.46,
    "end": 17.44,
    "text": "La motivación es"
  },
  {
    "start": 17.44,
    "end": 18.86,
    "text": "una chispa, dura"
  },
  {
    "start": 18.86,
    "end": 20.3,
    "text": "minutos, a veces"
  },
  {
    "start": 20.3,
    "end": 22.72,
    "text": "segundos. La disciplina"
  },
  {
    "start": 22.72,
    "end": 23.84,
    "text": "es el fuego"
  },
  {
    "start": 23.84,
    "end": 24.72,
    "text": "que se mantiene"
  },
  {
    "start": 24.72,
    "end": 25.98,
    "text": "en sentido aunque"
  },
  {
    "start": 25.98,
    "end": 28.84,
    "text": "llueva. Cuando depende"
  },
  {
    "start": 28.84,
    "end": 29.78,
    "text": "de tu ánimo,"
  },
  {
    "start": 30.1,
    "end": 31.06,
    "text": "dejas tu futuro"
  },
  {
    "start": 31.06,
    "end": 31.84,
    "text": "en manos de"
  },
  {
    "start": 31.84,
    "end": 32.78,
    "text": "tu peor día."
  },
  {
    "start": 33.6,
    "end": 34.74,
    "text": "Pero cuando construyes"
  },
  {
    "start": 34.74,
    "end": 36.28,
    "text": "un sistema, un"
  },
  {
    "start": 36.28,
    "end": 37.88,
    "text": "hábito, una rutina"
  },
  {
    "start": 37.88,
    "end": 38.82,
    "text": "que no negocia"
  },
  {
    "start": 38.82,
    "end": 39.53,
    "text": "con tus excusas,"
  },
  {
    "start": 40.54,
    "end": 42.18,
    "text": "abansas incluso cuando"
  },
  {
    "start": 42.18,
    "end": 43.14,
    "text": "no tienes ganas"
  },
  {
    "start": 43.14,
    "end": 45.72,
    "text": "de nada. No"
  },
  {
    "start": 45.72,
    "end": 46.66,
    "text": "esperes las ganas"
  },
  {
    "start": 46.66,
    "end": 48.42,
    "text": "para empezar. En"
  },
  {
    "start": 48.42,
    "end": 49.6,
    "text": "pieza y las"
  },
  {
    "start": 49.6,
    "end": 50.42,
    "text": "ganas van a"
  },
  {
    "start": 50.42,
    "end": 51.16,
    "text": "aparecer en el"
  },
  {
    "start": 51.16,
    "end": 53.92,
    "text": "camino. La gente"
  },
  {
    "start": 53.92,
    "end": 55.46,
    "text": "exitosa no es"
  },
  {
    "start": 55.46,
    "end": 56.38,
    "text": "más motivada que"
  },
  {
    "start": 56.38,
    "end": 57.68,
    "text": "tú, es más"
  },
  {
    "start": 57.68,
    "end": 59.32,
    "text": "disciplinada que tú."
  },
  {
    "start": 59.76,
    "end": 60.88,
    "text": "Elige la disciplina"
  },
  {
    "start": 60.88,
    "end": 62.32,
    "text": "hoy, aunque no"
  },
  {
    "start": 62.32,
    "end": 63.14,
    "text": "sientas nada."
  }
]