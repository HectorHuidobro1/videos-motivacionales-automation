[
  {
    "start": 0.0,
    "end": 1.28,
    "text": "¿Sabes cuál es"
  },
  {
    "start": 1.28,
    "end": 2.56,
    "text": "el verdadero miedo,"
  },
  {
    "start": 2.82,
    "end": 3.94,
    "text": "detrás de no"
  },
  {
    "start": 3.94,
    "end": 6.36,
    "text": "intentar algo? No"
  },
  {
    "start": 6.36,
    "end": 8.7,
    "text": "es fracasar. Es"
  },
  {
    "start": 8.7,
    "end": 9.68,
    "text": "que te vean"
  },
  {
    "start": 9.68,
    "end": 12.78,
    "text": "fracasar. Pero fracasar"
  },
  {
    "start": 12.78,
    "end": 15.34,
    "text": "en público duelenme"
  },
  {
    "start": 15.34,
    "end": 17.74,
    "text": "que imaginas. Porque"
  },
  {
    "start": 17.74,
    "end": 19.24,
    "text": "casi nadie está"
  },
  {
    "start": 19.24,
    "end": 20.68,
    "text": "mirando tanto como"
  },
  {
    "start": 20.68,
    "end": 23.3,
    "text": "crees. La gente"
  },
  {
    "start": 23.3,
    "end": 25.28,
    "text": "está demasiado ocupada,"
  },
  {
    "start": 25.7,
    "end": 26.84,
    "text": "viviendo su propia"
  },
  {
    "start": 26.84,
    "end": 28.88,
    "text": "vida, para archivar"
  },
  {
    "start": 28.88,
    "end": 31.6,
    "text": "la tuya. Ese"
  },
  {
    "start": 31.6,
    "end": 32.72,
    "text": "comentario que te"
  },
  {
    "start": 32.72,
    "end": 34.74,
    "text": "mes, esa risa"
  },
  {
    "start": 34.74,
    "end": 37.36,
    "text": "que anticipas, casi"
  },
  {
    "start": 37.36,
    "end": 39.72,
    "text": "nunca llega. Y"
  },
  {
    "start": 39.72,
    "end": 41.32,
    "text": "si llega, no"
  },
  {
    "start": 41.32,
    "end": 43.44,
    "text": "te define. Lo"
  },
  {
    "start": 43.44,
    "end": 44.24,
    "text": "que te define,"
  },
  {
    "start": 45.24,
    "end": 45.92,
    "text": "es si te"
  },
  {
    "start": 45.92,
    "end": 47.06,
    "text": "volvés a parar."
  },
  {
    "start": 48.76,
    "end": 49.84,
    "text": "Cada persona que"
  },
  {
    "start": 49.84,
    "end": 52.18,
    "text": "hoy admiras, falló"
  },
  {
    "start": 52.18,
    "end": 53.5,
    "text": "delante de otros,"
  },
  {
    "start": 54.56,
    "end": 55.52,
    "text": "antes de lograr"
  },
  {
    "start": 55.52,
    "end": 57.6,
    "text": "algo real. La"
  },
  {
    "start": 57.6,
    "end": 59.92,
    "text": "diferencia no fue"
  },
  {
    "start": 59.92,
    "end": 60.84,
    "text": "que evitaron la"
  },
  {
    "start": 60.84,
    "end": 62.94,
    "text": "vergüenza. Fue que"
  },
  {
    "start": 62.94,
    "end": 65.12,
    "text": "siguieron, aunque las"
  },
  {
    "start": 65.12,
    "end": 68.32,
    "text": "sintieron. Deja desperar"
  },
  {
    "start": 68.32,
    "end": 70.12,
    "text": "el momento perfecto,"
  },
  {
    "start": 70.42,
    "end": 71.52,
    "text": "para intentar sin"
  },
  {
    "start": 71.52,
    "end": 74.04,
    "text": "testigos. Porque ese"
  },
  {
    "start": 74.04,
    "end": 76.46,
    "text": "momento no existe."
  },
  {
    "start": 77.86,
    "end": 79.26,
    "text": "Arriesga de ahora,"
  },
  {
    "start": 80.22,
    "end": 81.38,
    "text": "con gente mirando,"
  },
  {
    "start": 81.76,
    "end": 83.6,
    "text": "el fracaso público"
  },
  {
    "start": 83.6,
    "end": 86.54,
    "text": "no te destruye."
  },
  {
    "start": 86.7,
    "end": 87.84,
    "text": "Te entrena."
  }
]