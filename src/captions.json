[
  {
    "start": 0.0,
    "end": 1.38,
    "text": "Sabías que tu"
  },
  {
    "start": 1.38,
    "end": 2.42,
    "text": "zona de confort"
  },
  {
    "start": 2.42,
    "end": 3.78,
    "text": "no te protege,"
  },
  {
    "start": 4.06,
    "end": 5.18,
    "text": "te está matando"
  },
  {
    "start": 5.18,
    "end": 7.84,
    "text": "lentamente. Cada día"
  },
  {
    "start": 7.84,
    "end": 8.76,
    "text": "que evitas el"
  },
  {
    "start": 8.76,
    "end": 10.02,
    "text": "cambio por miedo,"
  },
  {
    "start": 10.52,
    "end": 11.18,
    "text": "tu mundo se"
  },
  {
    "start": 11.18,
    "end": 12.36,
    "text": "hace más pequeño."
  },
  {
    "start": 14.0,
    "end": 15.12,
    "text": "La comodidad se"
  },
  {
    "start": 15.12,
    "end": 17.2,
    "text": "siente segura. Pero"
  },
  {
    "start": 17.2,
    "end": 18.06,
    "text": "es la trampa"
  },
  {
    "start": 18.06,
    "end": 19.6,
    "text": "más silenciosa que"
  },
  {
    "start": 19.6,
    "end": 21.74,
    "text": "existe. No duele"
  },
  {
    "start": 21.74,
    "end": 23.24,
    "text": "hoy, pero te"
  },
  {
    "start": 23.24,
    "end": 24.12,
    "text": "cuesta la vida"
  },
  {
    "start": 24.12,
    "end": 25.26,
    "text": "que pudiste tener."
  },
  {
    "start": 26.64,
    "end": 28.52,
    "text": "Crecer siempre incomoda."
  },
  {
    "start": 29.52,
    "end": 30.84,
    "text": "Los músculos se"
  },
  {
    "start": 30.84,
    "end": 32.1,
    "text": "rompen antes de"
  },
  {
    "start": 32.1,
    "end": 34.58,
    "text": "fortalecerse. Las ideas"
  },
  {
    "start": 34.58,
    "end": 36.16,
    "text": "se cuestionan antes"
  },
  {
    "start": 36.16,
    "end": 37.94,
    "text": "de valer. Y"
  },
  {
    "start": 37.94,
    "end": 39.34,
    "text": "las personas cambian"
  },
  {
    "start": 39.34,
    "end": 40.28,
    "text": "solo cuando el"
  },
  {
    "start": 40.28,
    "end": 41.48,
    "text": "dolor de quedarse,"
  },
  {
    "start": 42.3,
    "end": 43.14,
    "text": "supera al miedo"
  },
  {
    "start": 43.14,
    "end": 46.0,
    "text": "de avanzar. Salir"
  },
  {
    "start": 46.0,
    "end": 46.58,
    "text": "de tu zona"
  },
  {
    "start": 46.58,
    "end": 47.8,
    "text": "de confort no"
  },
  {
    "start": 47.8,
    "end": 48.46,
    "text": "es un salto"
  },
  {
    "start": 48.46,
    "end": 50.32,
    "text": "al vacío. Es"
  },
  {
    "start": 50.32,
    "end": 51.32,
    "text": "un paso hacia"
  },
  {
    "start": 51.32,
    "end": 52.76,
    "text": "quien realmente puedes"
  },
  {
    "start": 52.76,
    "end": 55.5,
    "text": "ser. Nadie construyó"
  },
  {
    "start": 55.5,
    "end": 57.02,
    "text": "algo grande quedándose"
  },
  {
    "start": 57.02,
    "end": 58.32,
    "text": "donde ya estaba."
  },
  {
    "start": 59.62,
    "end": 60.06,
    "text": "Hoy es un"
  },
  {
    "start": 60.06,
    "end": 60.94,
    "text": "buen día para"
  },
  {
    "start": 60.94,
    "end": 62.28,
    "text": "incomodarte un poco."
  },
  {
    "start": 63.32,
    "end": 64.8,
    "text": "Ese incomodo es"
  },
  {
    "start": 64.8,
    "end": 65.62,
    "text": "el precio de"
  },
  {
    "start": 65.62,
    "end": 66.82,
    "text": "tu próxima versión."
  }
]