    "end": 62.32,
    "text": "vuelva a costumbre."
  },
  {
    "start": 62.88,
    "end": 64.2,
    "text": "Así se construye"
  },
  {
    "start": 64.2,
    "end": 65.9,
    "text": "el coraje. No"
  },
  {
    "start": 65.9,
    "end": 66.86,
    "text": "en ausencia de"
  },
  {
    "start": 66.86,
    "end": 68.48,
    "text": "miedo, sino en"
  },
  {
    "start": 68.48,
    "end": 69.48,
    "text": "la repetición de"
  },
  {
    "start": 69.48,
    "end": 70.66,
    "text": "actuar frente a"
  },
  {
    "start": 70.66,
    "end": 73.08,
    "text": "él. Empieza hoy,"
  },
  {
