[
  {
    "start": 0.0,
    "end": 1.44,
    "text": "De verdad, crees"
  },
  {
    "start": 1.44,
    "end": 2.52,
    "text": "que más dinero"
  },
  {
    "start": 2.52,
    "end": 3.28,
    "text": "te va a"
  },
  {
    "start": 3.28,
    "end": 4.42,
    "text": "ser más feliz."
  },
  {
    "start": 5.56,
    "end": 6.54,
    "text": "Mira lo bien."
  },
  {
    "start": 7.44,
    "end": 8.38,
    "text": "Mucha gente que"
  },
  {
    "start": 8.38,
    "end": 9.4,
    "text": "ya tiene todo"
  },
  {
    "start": 9.4,
    "end": 11.0,
    "text": "lo material sigue"
  },
  {
    "start": 11.0,
    "end": 12.46,
    "text": "vacía por dentro."
  },
  {
    "start": 13.6,
    "end": 14.52,
    "text": "Y mucha gente,"
  },
  {
    "start": 14.78,
    "end": 15.98,
    "text": "con poco, vive"
  },
  {
    "start": 15.98,
    "end": 18.54,
    "text": "en paz. El"
  },
  {
    "start": 18.54,
    "end": 20.3,
    "text": "dinero resuelve problemas"
  },
  {
    "start": 20.3,
    "end": 21.82,
    "text": "de dinero. Nada"
  },
  {
    "start": 21.82,
    "end": 24.18,
    "text": "más. No resuelve"
  },
  {
    "start": 24.18,
    "end": 25.98,
    "text": "el miedo. No"
  },
  {
    "start": 25.98,
    "end": 27.28,
    "text": "resuelve la soledad."
  },
  {
    "start": 27.28,
    "end": 29.18,
    "text": "No resuelve la"
  },
  {
    "start": 29.18,
    "end": 30.7,
    "text": "falta de propósito."
  },
  {
    "start": 32.6,
    "end": 33.6,
    "text": "Si persigue es"
  },
  {
    "start": 33.6,
    "end": 34.94,
    "text": "cada peso pensando"
  },
  {
    "start": 34.94,
    "end": 35.96,
    "text": "que ahí está"
  },
  {
    "start": 35.96,
    "end": 37.96,
    "text": "la felicidad, vas"
  },
  {
    "start": 37.96,
    "end": 38.52,
    "text": "a llegar a"
  },
  {
    "start": 38.52,
    "end": 39.56,
    "text": "la meta y"
  },
  {
    "start": 39.56,
    "end": 40.18,
    "text": "vas a seguir"
  },
  {
    "start": 40.18,
    "end": 41.5,
    "text": "sintiendo el mismo"
  },
  {
    "start": 41.5,
    "end": 43.18,
    "text": "vacío, solo que"
  },
  {
    "start": 43.18,
    "end": 44.38,
    "text": "con mejores muebles."
  },
  {
    "start": 46.48,
    "end": 47.8,
    "text": "La felicidad real"
  },
  {
    "start": 47.8,
    "end": 49.76,
    "text": "se construye antes."
  },
  {
    "start": 50.74,
    "end": 51.8,
    "text": "Con paz interior,"
  },
  {
    "start": 52.72,
    "end": 54.26,
    "text": "con relaciones sanas,"
  },
  {
    "start": 54.82,
    "end": 55.92,
    "text": "con un propósito"
  },
  {
    "start": 55.92,
    "end": 59.24,
    "text": "claro. Cuando eso"
  },
  {
    "start": 59.24,
    "end": 60.64,
    "text": "ya está firme,"
  },
  {
    "start": 61.06,
    "end": 61.7,
    "text": "el dinero se"
  },
  {
    "start": 61.7,
    "end": 63.42,
    "text": "vuelve una herramienta,"
  },
  {
    "start": 63.72,
    "end": 65.48,
    "text": "no una salvación."
  },
  {
    "start": 66.84,
    "end": 68.66,
    "text": "Trabaja por prosperar,"
  },
  {
    "start": 68.76,
    "end": 70.4,
    "text": "sí. Pero no"
  },
  {
    "start": 70.4,
    "end": 71.24,
    "text": "le pidas al"
  },
  {
    "start": 71.24,
    "end": 72.34,
    "text": "dinero lo que"
  },
  {
    "start": 72.34,
    "end": 73.28,
    "text": "solo tú te"
  },
  {
    "start": 73.28,
    "end": 73.84,
    "text": "puedes dar."
  }
]