    "end": 44.32,
    "text": "llamada difícil, una"
  },
  {
    "start": 44.32,
    "end": 45.72,
    "text": "decisión importante,"
  },
  {
    "start": 46.46,
    "end": 47.12,
    "text": "o un cambio"
