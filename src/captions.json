  },
  {
    "start": 35.34,
    "end": 36.04,
    "text": "con él en"
  },
  {
    "start": 36.04,
    "end": 38.12,
    "text": "el cuerpo. La"
  },
  {
    "start": 38.12,
    "end": 39.46,
    "text": "próxima vez que"
  },
  {
    "start": 39.46,
    "end": 40.9,
    "text": "el miedo aparezca,"
  },
  {
    "start": 41.14,
    "end": 42.06,
    "text": "antes de una"
  },
  {
