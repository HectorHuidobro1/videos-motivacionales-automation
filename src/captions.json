    "end": 29.28,
    "text": "sostiene cuando entras."
  },
  {
    "start": 30.16,
    "end": 31.1,
    "text": "Si hoy sientes"
  },
  {
    "start": 31.1,
    "end": 32.24,
    "text": "que estás invirtiendo"
  },
  {
    "start": 32.24,
    "end": 33.4,
    "text": "esfuerzos sin ver"
  },
  {
    "start": 33.4,
    "end": 35.18,
    "text": "resultados, no estás"
  },
  {
    "start": 35.18,
    "end": 36.28,
    "text": "perdiendo el tiempo."
  },
  {
    "start": 37.18,
    "end": 38.04,
    "text": "Estás construyendo"
  },
  {
    "start": 38.04,
    "end": 39.48,
    "text": "los cimientos, que"
  },
  {
    "start": 39.48,
    "end": 40.78,
    "text": "después nadie podrá"
  },
  {
    "start": 40.78,
    "end": 43.1,
    "text": "derribar. La oportunidad"
  },
  {
    "start": 43.1,
    "end": 44.5,
    "text": "no crea tu"
  },
  {
    "start": 44.5,
    "end": 46.24,
    "text": "capacidad, sólo la"
  },
  {
    "start": 46.24,
    "end": 48.34,
    "text": "revela. Por eso"
  },
  {
    "start": 48.34,
    "end": 49.98,
    "text": "preparate incluso cuando"
  },
  {
    "start": 49.98,
    "end": 51.96,
    "text": "nadie mire, incluso"
  },
  {
    "start": 51.96,
    "end": 52.98,
    "text": "cuando parezca que"
  },
  {
    "start": 52.98,
    "end": 55.08,
    "text": "nada abanza. El"
  },
  {
    "start": 55.08,
    "end": 55.7,
    "text": "día que llegue"
  },
  {
    "start": 55.7,
    "end": 57.06,
    "text": "tu momento no"
  },
  {
    "start": 57.06,
    "end": 58.1,
    "text": "vas a improvisar,"
  },
  {
    "start": 58.66,
    "end": 59.48,
    "text": "vas a responder"
  },
  {
    "start": 59.48,
    "end": 60.44,
    "text": "con todo lo"
  },
  {
    "start": 60.44,
    "end": 61.14,
    "text": "que entren hasta"
  },
  {
    "start": 61.14,
    "end": 63.94,
    "text": "en silencio. Preparate"
  },
  {
    "start": 63.94,
    "end": 65.06,
    "text": "hoy para el"
  },
  {
    "start": 65.06,
    "end": 65.9,
    "text": "éxito que aún"
  },
  {
    "start": 65.9,
    "end": 66.38,
