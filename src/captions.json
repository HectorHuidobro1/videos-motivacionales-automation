[
  {
    "start": 0.0,
    "end": 1.2,
    "text": "Cada vez que"
  },
  {
    "start": 1.2,
    "end": 3.06,
    "text": "evitas decidir, ya"
  },
  {
    "start": 3.06,
    "end": 5.02,
    "text": "decidiste, dejar que"
  },
  {
    "start": 5.02,
    "end": 6.12,
    "text": "el tiempo elija"
  },
  {
    "start": 6.12,
    "end": 8.22,
    "text": "por voz. Postergar"
  },
  {
    "start": 8.22,
    "end": 9.6,
    "text": "una decisión no"
  },
  {
    "start": 9.6,
    "end": 11.14,
    "text": "la evita, solo"
  },
  {
    "start": 11.14,
    "end": 12.06,
    "text": "le presta el"
  },
  {
    "start": 12.06,
    "end": 13.16,
    "text": "control al miedo,"
  },
  {
    "start": 13.7,
    "end": 14.38,
    "text": "a la suerte,"
  },
  {
    "start": 15.08,
    "end": 15.54,
    "text": "o a otra"
  },
  {
    "start": 15.54,
    "end": 18.54,
    "text": "persona. Cresque esperar"
  },
  {
    "start": 18.54,
    "end": 20.44,
    "text": "seguro, pero mientras"
  },
  {
    "start": 20.44,
    "end": 22.0,
    "text": "dudas, la vida"
  },
  {
    "start": 22.0,
    "end": 23.64,
    "text": "sigue moviéndose sin"
  },
  {
    "start": 23.64,
    "end": 24.8,
    "text": "pedir de permiso."
  },
  {
    "start": 25.36,
    "end": 26.66,
    "text": "La oportunidad se"
  },
  {
    "start": 26.66,
    "end": 28.22,
    "text": "enfriya, la relación"
  },
  {
    "start": 28.22,
    "end": 30.04,
    "text": "se desgasta, el"
  },
  {
    "start": 30.04,
    "end": 30.86,
    "text": "lugar lo toma"
  },
  {
    "start": 30.86,
    "end": 33.66,
    "text": "otro. No decidir"
  },
  {
    "start": 33.66,
    "end": 34.7,
    "text": "también es una"
  },
  {
    "start": 34.7,
    "end": 36.72,
    "text": "decisión, la más"
  },
  {
    "start": 36.72,
    "end": 37.74,
    "text": "cara de todas,"
  },
  {
    "start": 38.32,
    "end": 39.0,
    "text": "porque se paga"
  },
  {
    "start": 39.0,
    "end": 40.64,
    "text": "en cuota silenciosas"
  },
  {
    "start": 40.64,
    "end": 41.96,
    "text": "de oportunidades que"
  },
  {
    "start": 41.96,
    "end": 44.64,
    "text": "no vuelven. No"
  },
  {
    "start": 44.64,
    "end": 46.34,
    "text": "necesitas ser desatotal"
  },
  {
    "start": 46.34,
    "end": 48.52,
    "text": "para avanzar, necesitas"
  },
  {
    "start": 48.52,
    "end": 49.52,
    "text": "soltar la idea"
  },
  {
    "start": 49.52,
    "end": 50.24,
    "text": "de que esperar"
  },
  {
    "start": 50.24,
    "end": 51.26,
    "text": "más de va"
  },
  {
    "start": 51.26,
    "end": 51.86,
    "text": "a dar más"
  },
  {
    "start": 51.86,
    "end": 54.06,
    "text": "claridad. La claridad"
  },
  {
    "start": 54.06,
    "end": 55.92,
    "text": "llega actuando, no"
  },
  {
    "start": 55.92,
    "end": 58.08,
    "text": "quedando de quieto."
  },
  {
    "start": 58.88,
    "end": 60.54,
    "text": "Elige hoy, aunque"
  },
  {
    "start": 60.54,
    "end": 61.68,
    "text": "sea con miedo,"
  },
  {
    "start": 62.3,
    "end": 63.1,
    "text": "aunque no sea"
  },
  {
    "start": 63.1,
    "end": 65.62,
    "text": "perfecto. Una decisión"
  },
  {
    "start": 65.62,
    "end": 67.06,
    "text": "mala se corrige,"
  },
  {
    "start": 67.64,
    "end": 69.18,
    "text": "la indecisión te"
  },
  {
    "start": 69.18,
    "end": 70.08,
    "text": "condena a quedar"
  },
  {
    "start": 70.08,
    "end": 70.94,
    "text": "de igual para"
  },
  {
    "start": 70.94,
    "end": 71.3,
    "text": "siempre."
  }
]