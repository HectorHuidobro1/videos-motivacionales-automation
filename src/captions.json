[
  {
    "start": 0.0,
    "end": 1.08,
    "text": "¿Sabes por qué"
  },
  {
    "start": 1.08,
    "end": 2.06,
    "text": "el éxito parece"
  },
  {
    "start": 2.06,
    "end": 2.9,
    "text": "llegar de la"
  },
  {
    "start": 2.9,
    "end": 3.8,
    "text": "nada a algunas"
  },
  {
    "start": 3.8,
    "end": 5.56,
    "text": "personas? ¿Por qué"
  },
  {
    "start": 5.56,
    "end": 6.22,
    "text": "no lo viste"
  },
  {
    "start": 6.22,
    "end": 8.26,
    "text": "llegar? Sólo viste"
  },
  {
    "start": 8.26,
    "end": 10.54,
    "text": "el resultado. Antes"
  },
  {
    "start": 10.54,
    "end": 11.42,
    "text": "de esa victoria,"
  },
  {
    "start": 11.98,
    "end": 12.96,
    "text": "hubo años de"
  },
  {
    "start": 12.96,
    "end": 14.56,
    "text": "preparación silenciosa,"
  },
  {
    "start": 15.2,
    "end": 16.92,
    "text": "madrugadas sin aplausos,"
  },
  {
    "start": 17.42,
    "end": 18.44,
    "text": "intentos que nadie"
  },
  {
    "start": 18.44,
    "end": 20.42,
    "text": "se lebró, errores,"
  },
  {
    "start": 20.86,
    "end": 22.18,
    "text": "corregidos en privado."
  },
  {
    "start": 23.46,
    "end": 24.46,
    "text": "El talento abre"
  },
  {
    "start": 24.46,
    "end": 26.08,
    "text": "una puerta, pero"
  },
  {
    "start": 26.08,
    "end": 27.6,
    "text": "la preparación es"
  },
  {
