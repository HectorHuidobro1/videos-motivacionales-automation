    "end": 53.98,
    "text": "va a esperando."
  },
  {
    "start": 53.98,
    "end": 55.9,
    "text": "Actúa con miedo,"
  },
  {
    "start": 56.6,
    "end": 57.34,
    "text": "una y otra"
  },
  {
    "start": 57.34,
    "end": 58.96,
    "text": "vez, hasta que"
  },
  {
    "start": 58.96,
    "end": 60.5,
    "text": "ese temblor se"
  },
  {
